# ZonaGrupos — Apache (Spaceship / cPanel)
# Sube este archivo junto con index.php, grupo.php, css/, js/ a public_html

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  RewriteCond %{HTTPS} off
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
  RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

  RewriteRule ^og/portada\.png$ og/portada.php [L]
  RewriteRule ^og/grupo/([a-zA-Z0-9_-]+)\.png$ og/grupo.php?slug=$1 [L,QSA]
  RewriteRule ^robots\.txt$ robots.php [L]
  RewriteRule ^sitemap\.xml$ sitemap.php [L]

  RewriteRule ^api/(.*)$ api/$1 [L,QSA]

  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  RewriteRule ^grupo/([a-zA-Z0-9_-]+)/?$ grupo.php?slug=$1 [L,QSA]

  RewriteRule ^terminos/?$ terminos.php [L,QSA]

  RewriteRule ^zg-x7k9m2p/?$ zg-x7k9m2p/index.html [L,QSA]
  RewriteRule ^zg-x7k9m2p/(.*)$ zg-x7k9m2p/$1 [L,QSA]

  RewriteRule ^$ index.php [L]
  RewriteRule ^index\.html$ index.php [L,QSA]
  RewriteRule ^grupo\.html$ / [L,R=301]
</IfModule>

<IfModule mod_mime.c>
  AddType application/javascript .js
  AddType text/css .css
</IfModule>

Options -Indexes

# ── Caché: CSS/JS/HTML siempre actualizados tras git pull ──
<IfModule mod_headers.c>
  <FilesMatch "\.(php|html)$">
    Header always set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
    Header always set Pragma "no-cache"
    Header always set Expires "0"
  </FilesMatch>

  <FilesMatch "\.(css|js)$">
    Header always set Cache-Control "no-cache, must-revalidate, max-age=0"
    Header always set Pragma "no-cache"
    Header always set Expires "0"
  </FilesMatch>

  <FilesMatch "\.(webmanifest|json)$">
    Header always set Cache-Control "no-cache, must-revalidate, max-age=0"
  </FilesMatch>
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 0 seconds"
  ExpiresByType text/javascript "access plus 0 seconds"
  ExpiresByType application/javascript "access plus 0 seconds"
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType application/xhtml+xml "access plus 0 seconds"
</IfModule>
