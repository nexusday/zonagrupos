 */

return [
    'bd_host'    => 'localhost',
    'bd_nombre'  => 'nzoaqaxydg_zonagrupos_db',
    'bd_usuario' => 'nzoaqaxydg_zonagrupos_user',
    'bd_clave'   => 'TU_CLAVE_MYSQL',

    'origenes' => [
        'https://zonagrupos.lat',
        'https://www.zonagrupos.lat',
    ],
