# ZonaGrupos — Repo completo en public_html (git clone / git pull aquí)
# Los HTML, CSS y JS viven en public/; las URLs siguen siendo /css/, /js/, etc.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # API PHP
  RewriteRule ^api/(.*)$ api/$1 [L,QSA]

  # Estáticos siempre desde public/ (no usar copias viejas en la raíz)
  RewriteRule ^css/(.*)$ public/css/$1 [L]
  RewriteRule ^js/(.*)$ public/js/$1 [L]
  RewriteRule ^img/(.*)$ public/img/$1 [L]

  # Panel admin (ruta debe coincidir con ADMIN_RUTA en sun.env)
  RewriteRule ^zg-x7k9m2p/?$ public/zg-x7k9m2p/index.html [L,QSA]
  RewriteRule ^zg-x7k9m2p/(.*)$ public/zg-x7k9m2p/$1 [L,QSA]

  # Página de grupo
  RewriteRule ^grupo/[a-zA-Z0-9_-]+/?$ public/grupo.html [L,QSA]

  # Inicio
  RewriteRule ^$ public/index.html [L]
</IfModule>

Options -Indexes
