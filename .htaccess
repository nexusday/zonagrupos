# ZonaGrupos — Repo completo en public_html (git clone / git pull aquí)
# Todo el sitio (HTML, CSS, JS, imágenes) se sirve desde public/
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Forzar HTTPS (evita duplicado http/https en Google)
  RewriteCond %{HTTPS} off
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Dominio canónico sin www
  RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
  RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

  # Bloquear carpetas internas del repositorio
  RewriteRule ^(\.git|base-datos|scripts|logs|node_modules|vendor)(/|$) - [F,L]

  # Bloquear archivos sensibles o de desarrollo en la raíz
  RewriteRule ^(config\.env|config\.env\.local|sun\.env|package\.json|servidor\.js|enrutador\.php|\.gitignore)$ - [F,L]

  # No exponer la ruta /public/ en la URL
  RewriteRule ^public/ - [F,L]

  # SEO e imágenes para redes
  RewriteRule ^og/portada\.png$ public/og/portada.php [L]
  RewriteRule ^og/grupo/([a-zA-Z0-9_-]+)\.png$ public/og/grupo.php?slug=$1 [L,QSA]
  RewriteRule ^robots\.txt$ public/robots.php [L]
  RewriteRule ^sitemap\.xml$ public/sitemap.php [L]

  # API PHP
  RewriteRule ^api/(.*)$ api/$1 [L,QSA]

  # Rutas amigables
  RewriteRule ^terminos/?$ public/terminos.php [L]
  RewriteRule ^tema/([a-zA-Z0-9_-]+)/?$ public/index.php?tema=$1 [L,QSA]
  RewriteRule ^grupo/([a-zA-Z0-9_-]+)/?$ public/grupo.php?slug=$1 [L,QSA]
  RewriteRule ^zg-x7k9m2p/?$ public/zg-x7k9m2p/index.html [L,QSA]
  RewriteRule ^zg-x7k9m2p/(.*)$ public/zg-x7k9m2p/$1 [L,QSA]

  # Inicio (SEO dinámico)
  RewriteRule ^$ public/index.php [L]
  RewriteRule ^index\.php$ public/index.php [L,QSA]
  RewriteRule ^index\.html$ public/index.php [L,QSA]
  RewriteRule ^grupo\.html$ / [L,R=301]

  # Todo lo demás que exista en public/ (css, js, img, fuentes, etc.)
  RewriteCond %{DOCUMENT_ROOT}/public/$1 -f [OR]
  RewriteCond %{DOCUMENT_ROOT}/public/$1 -d
  RewriteRule ^(.+)$ public/$1 [L]
</IfModule>

# Si Apache busca index en la raíz, usar el de public/
DirectoryIndex public/index.php public/index.html

<IfModule mod_authz_core.c>
  <Files "config.env">
    Require all denied
  </Files>
  <Files "config.env.local">
    Require all denied
  </Files>
  <Files "sun.env">
    Require all denied
  </Files>
</IfModule>

Options -Indexes

# ── Caché: CSS/JS/HTML siempre actualizados tras git pull ──
<IfModule mod_headers.c>
  Header always unset X-Powered-By
  Header unset X-Powered-By

  <FilesMatch "\.(php|html)$">
    Header always set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
    Header always set Pragma "no-cache"
    Header always set Expires "0"
  </FilesMatch>

  <FilesMatch "\.(css|js)$">
    Header always set Cache-Control "no-cache, must-revalidate, max-age=0"
    Header always set Pragma "no-cache"
    Header always set Expires "0"
  </FilesMatch>

  <FilesMatch "\.(webmanifest|json)$">
    Header always set Cache-Control "no-cache, must-revalidate, max-age=0"
  </FilesMatch>
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 0 seconds"
  ExpiresByType application/javascript "access plus 0 seconds"
  ExpiresByType text/javascript "access plus 0 seconds"
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType application/xhtml+xml "access plus 0 seconds"
</IfModule>
