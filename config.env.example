# --- Spaceship (hosting compartido) ---
BD_HOST=localhost
BD_NOMBRE=nzoaqaxydg_zonagrupos_db
BD_USUARIO=nzoaqaxydg_tu_usuario
BD_CLAVE=tu_clave_mysql

# URL pública de tu sitio (para CORS en hosting)
APP_URL=https://tudominio.com

# Puerto local (solo desarrollo con Node)
PUERTO=4600
